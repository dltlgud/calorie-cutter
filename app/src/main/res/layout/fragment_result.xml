<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="추천 루틴"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface" />

        <TextView
            android:id="@+id/tv_result_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="나에게 맞는 운동 조합이에요"
            android:textSize="13sp"
            android:textColor="@color/on_surface_secondary"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- 운동 목록 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView_recommendations"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false"
        android:scrollbars="none" />

    <!-- 하단 버튼 영역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:elevation="4dp">

        <Button
            android:id="@+id/btn_save_routine"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="루틴 저장하기"
            android:background="@drawable/btn_rectangle"
            app:backgroundTint="@color/primary"
            android:textColor="@color/on_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btn_return"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="홈으로 돌아가기"
            android:background="@drawable/btn_outlined"
            app:backgroundTint="@android:color/transparent"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:stateListAnimator="@null" />
    </LinearLayout>

</LinearLayout>
