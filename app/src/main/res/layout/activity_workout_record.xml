<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical"
        android:background="@color/surface"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/on_surface"
            android:contentDescription="뒤로가기" />

        <TextView
            android:id="@+id/tvWorkoutSelected"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="운동 이름"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:layout_marginStart="4dp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- 상단 통계 바: 총 횟수 + 볼륨 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/surface"
        android:elevation="1dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="총 횟수"
                android:textSize="11sp"
                android:textColor="@color/on_surface_secondary" />

            <TextView
                android:id="@+id/tvTotalReps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0회"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:layout_gravity="center_vertical"
            android:background="@color/border" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="볼륨"
                android:textSize="11sp"
                android:textColor="@color/on_surface_secondary" />

            <TextView
                android:id="@+id/tvTotalVolume"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0kg"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface" />
        </LinearLayout>
    </LinearLayout>

    <!-- 타이머 패널 (원형 디자인) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:elevation="4dp"
        android:gravity="center_horizontal"
        android:paddingTop="20dp"
        android:paddingBottom="16dp">

        <!-- 원형 타이머: 가운데 시간, 가장자리 흘러가는 arc -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/timerProgressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                app:indicatorSize="210dp"
                app:trackThickness="12dp"
                app:indicatorColor="@color/primary"
                app:trackColor="@color/border"
                app:trackCornerRadius="6dp"
                android:max="3600"
                android:progress="0"
                android:indeterminate="false" />

            <LinearLayout
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvTimerStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="시작 전"
                    android:textSize="12sp"
                    android:letterSpacing="0.05"
                    android:textColor="@color/on_surface_secondary" />

                <TextView
                    android:id="@+id/tvWorkoutTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textSize="44sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="@color/on_surface"
                    android:gravity="center"
                    android:includeFontPadding="false" />
            </LinearLayout>
        </FrameLayout>

        <!-- 세트 수 + 시작/완료 버튼 행 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_chip_unselected"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/tvSetCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="세트"
                    android:textSize="11sp"
                    android:textColor="@color/on_surface_secondary"
                    android:gravity="center" />
            </LinearLayout>

            <Button
                android:id="@+id/btnStartWorkout"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:text="운동 시작"
                android:background="@drawable/btn_rectangle"
                app:backgroundTint="@color/primary"
                android:textColor="@color/on_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnFinishWorkout"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:text="✓  운동 완료"
                android:background="@drawable/btn_rectangle"
                app:backgroundTint="@color/success"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </LinearLayout>

    <!-- 스크롤 영역 -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 메모 -->
            <EditText
                android:id="@+id/etMemo"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="메모 (선택사항)"
                android:background="@drawable/edittext_modern"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textSize="14sp"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_secondary"
                android:layout_marginBottom="16dp" />

            <!-- 세트 목록 -->
            <LinearLayout
                android:id="@+id/setContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- 세트 추가/삭제 버튼 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btnRemoveSet"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/btn_outlined"
                    app:backgroundTint="@android:color/transparent"
                    android:text="− 세트 삭제"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnAddSet"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/btn_rectangle"
                    app:backgroundTint="@color/primary"
                    android:text="+ 세트 추가"
                    android:textColor="@color/on_primary"
                    android:textSize="14sp"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- 운동 추가 / 불러오기 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnAddWorkout"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/btn_rectangle"
                    app:backgroundTint="@color/primary_dark"
                    android:text="다른 운동 추가"
                    android:textColor="@color/on_primary"
                    android:textSize="13sp"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnLoadWorkout"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/btn_outlined"
                    app:backgroundTint="@android:color/transparent"
                    android:text="루틴 불러오기"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- 운동 완료 요약 카드 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/summaryLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/success"
                app:strokeWidth="1.5dp"
                app:cardBackgroundColor="@color/success_light">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvSummaryTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="운동 완료! 🎉"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/success"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvSummaryTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="운동 시간: 0분"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:id="@+id/tvSummaryCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="운동 개수: 0세트"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvSummaryVolume"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="총 볼륨: 0kg"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvSummaryExerciseNames"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="운동: 없음"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginTop="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">

                        <Button
                            android:id="@+id/btnShareSummary"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="공유하기"
                            android:background="@drawable/btn_rectangle"
                            app:backgroundTint="@color/success"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:stateListAnimator="@null" />

                        <Button
                            android:id="@+id/btnGoHome"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="홈으로"
                            android:background="@drawable/btn_rectangle"
                            app:backgroundTint="@color/primary"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:stateListAnimator="@null" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
