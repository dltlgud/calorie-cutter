<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fragment_library_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="라이브러리"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="운동 정보를 찾아보세요"
            android:textSize="13sp"
            android:textColor="@color/on_surface_secondary"
            android:layout_marginBottom="14dp" />

        <!-- 검색창 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:background="@drawable/edittext_modern"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                app:tint="@color/on_surface_secondary" />

            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:hint="운동 이름으로 검색"
                android:textSize="14sp"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_secondary"
                android:background="@null"
                android:singleLine="true"
                android:imeOptions="actionSearch"
                android:inputType="text" />
        </LinearLayout>
    </LinearLayout>

    <!-- 카테고리 칩 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="@color/surface"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:id="@+id/ll_categories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.chip.Chip
                android:id="@+id/btn_bookmark"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="⭐  북마크"
                android:textSize="13sp"
                android:textColor="@color/on_surface_secondary"
                android:layout_marginEnd="6dp"
                app:chipBackgroundColor="@color/surface"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="1.5dp"
                app:chipCornerRadius="20dp"
                app:checkedIconVisible="false"
                app:chipMinHeight="38dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btn_all"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="전체"
                android:textSize="13sp"
                android:textColor="@color/white"
                android:layout_marginEnd="6dp"
                app:chipBackgroundColor="@color/primary"
                app:chipStrokeWidth="0dp"
                app:chipCornerRadius="20dp"
                app:checkedIconVisible="false"
                app:chipMinHeight="38dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btn_chest"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="가슴"
                android:textSize="13sp"
                android:textColor="@color/on_surface_secondary"
                android:layout_marginEnd="6dp"
                app:chipBackgroundColor="@color/surface"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="1.5dp"
                app:chipCornerRadius="20dp"
                app:checkedIconVisible="false"
                app:chipMinHeight="38dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="등"
                android:textSize="13sp"
                android:textColor="@color/on_surface_secondary"
                android:layout_marginEnd="6dp"
                app:chipBackgroundColor="@color/surface"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="1.5dp"
                app:chipCornerRadius="20dp"
                app:checkedIconVisible="false"
                app:chipMinHeight="38dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btn_shoulders"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="어깨"
                android:textSize="13sp"
                android:textColor="@color/on_surface_secondary"
                android:layout_marginEnd="6dp"
                app:chipBackgroundColor="@color/surface"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="1.5dp"
                app:chipCornerRadius="20dp"
                app:checkedIconVisible="false"
                app:chipMinHeight="38dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btn_arms"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="팔"
                android:textSize="13sp"
                android:textColor="@color/on_surface_secondary"
                android:layout_marginEnd="6dp"
                app:chipBackgroundColor="@color/surface"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="1.5dp"
                app:chipCornerRadius="20dp"
                app:checkedIconVisible="false"
                app:chipMinHeight="38dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btn_legs"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="하체"
                android:textSize="13sp"
                android:textColor="@color/on_surface_secondary"
                app:chipBackgroundColor="@color/surface"
                app:chipStrokeColor="@color/border"
                app:chipStrokeWidth="1.5dp"
                app:chipCornerRadius="20dp"
                app:checkedIconVisible="false"
                app:chipMinHeight="38dp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border" />

    <!-- 운동 목록 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_exercises"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false" />

</LinearLayout>
