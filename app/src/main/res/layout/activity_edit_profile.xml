<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:background="@color/surface"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/on_surface"
            android:contentDescription="뒤로가기" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="내 정보 편집"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 프로필 사진 -->
            <FrameLayout
                android:id="@+id/fl_profile"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_profile"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_profile_circle"
                    style="@style/CircleImageView" />

                <TextView
                    android:id="@+id/tv_profile_hint"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="📷"
                    android:textSize="28sp" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="사진을 눌러 변경"
                android:textSize="12sp"
                android:textColor="@color/on_surface_secondary"
                android:layout_marginBottom="24dp" />

            <!-- 닉네임 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="닉네임"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/et_nickname"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="닉네임 입력"
                        android:background="@drawable/edittext_modern"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="15sp"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/on_surface_secondary"
                        android:inputType="text" />

                    <TextView
                        android:id="@+id/tv_nickname_error"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/danger"
                        android:layout_marginTop="4dp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 비밀번호 변경 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="비밀번호 변경"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="변경하지 않으려면 비워두세요"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_secondary"
                        android:layout_marginBottom="10dp" />

                    <EditText
                        android:id="@+id/et_current_pwd"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="현재 비밀번호"
                        android:background="@drawable/edittext_modern"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="15sp"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/on_surface_secondary"
                        android:inputType="textPassword"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/et_new_pwd"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="새 비밀번호 (8자 이상, 영문+숫자)"
                        android:background="@drawable/edittext_modern"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="15sp"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/on_surface_secondary"
                        android:inputType="textPassword"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/et_new_pwd_confirm"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="새 비밀번호 확인"
                        android:background="@drawable/edittext_modern"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="15sp"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/on_surface_secondary"
                        android:inputType="textPassword" />

                    <TextView
                        android:id="@+id/tv_pwd_error"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/danger"
                        android:layout_marginTop="4dp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 저장 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:padding="16dp"
        android:elevation="4dp">

        <Button
            android:id="@+id/btn_save_profile"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="저장하기"
            android:textColor="@color/on_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/btn_rectangle"
            app:backgroundTint="@color/primary"
            android:stateListAnimator="@null" />
    </LinearLayout>
</LinearLayout>
