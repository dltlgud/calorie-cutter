<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 헤더: 이전 버튼 + 타이틀 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="16dp"
            android:background="@color/background">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                android:tint="@color/on_surface"
                android:contentDescription="뒤로가기" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="회원가입"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- 프로필 사진 섹션 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="16dp"
            android:paddingBottom="20dp">

            <FrameLayout
                android:id="@+id/fl_profile"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_profile"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_profile_circle"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/CircleImageView" />

                <TextView
                    android:id="@+id/tv_profile_hint"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="📷"
                    android:textSize="30sp" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="프로필 사진 선택 (선택사항)"
                android:textSize="12sp"
                android:textColor="@color/on_surface_secondary"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- 입력 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- 이름 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="이름"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/et_name"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/edittext_modern"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="textPersonName"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/on_surface_secondary"
                    android:hint="홍길동 (한글만 가능)"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tv_name_error"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/danger"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="4dp"
                    android:visibility="gone" />

                <!-- 닉네임 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="닉네임"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/et_nickname"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/edittext_modern"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/on_surface_secondary"
                    android:hint="2~20자 (예: 건강왕)"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tv_nickname_error"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/danger"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="4dp"
                    android:visibility="gone" />

                <!-- 이메일 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="이메일"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/edittext_modern"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/on_surface_secondary"
                    android:hint="example@email.com"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tv_email_error"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/danger"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="4dp"
                    android:visibility="gone" />

                <!-- 비밀번호 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="비밀번호"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/et_pwd"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/edittext_modern"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="textPassword"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/on_surface_secondary"
                    android:hint="8자 이상, 영문+숫자 포함"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tv_pwd_error"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/danger"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="4dp"
                    android:visibility="gone" />

                <!-- 비밀번호 확인 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="비밀번호 확인"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/et_pwd_confirm"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/edittext_modern"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="textPassword"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/on_surface_secondary"
                    android:hint="비밀번호를 다시 입력"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tv_pwd_confirm_error"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/danger"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="4dp"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btn_register"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="36dp"
            android:text="가입하기"
            android:textColor="@color/on_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/btn_rectangle"
            app:backgroundTint="@color/primary"
            android:stateListAnimator="@null" />

    </LinearLayout>
</ScrollView>
