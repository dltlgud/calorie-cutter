<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface"
    android:paddingBottom="24dp">

    <!-- 드래그 핸들 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@color/border"
        android:backgroundTint="@color/border" />

    <!-- 날짜 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tv_bs_date"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="날짜"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border" />

    <!-- 운동 기록 섹션 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏋️"
                android:textSize="16sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="운동 기록"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface" />
        </LinearLayout>

        <!-- 운동 항목들이 동적으로 추가되는 컨테이너 -->
        <LinearLayout
            android:id="@+id/ll_bs_workouts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/tv_bs_workout_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="운동 기록 없음"
            android:textSize="13sp"
            android:textColor="@color/on_surface_secondary"
            android:visibility="gone" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border" />

    <!-- 식단 기록 섹션 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍽️"
                android:textSize="16sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="식단 기록"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_bs_diet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="식단 기록 없음"
            android:textSize="13sp"
            android:textColor="@color/on_surface_secondary" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border" />

    <!-- 액션 버튼들 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/btn_bs_workout"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:text="운동 기록하기"
            android:background="@drawable/btn_rectangle"
            app:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btn_bs_diet"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:text="식단 기록하기"
            android:background="@drawable/btn_outlined"
            app:backgroundTint="@android:color/transparent"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_bs_routine"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:text="루틴 추천받기"
        android:background="@android:color/transparent"
        android:textColor="@color/on_surface_secondary"
        android:textSize="14sp"
        android:stateListAnimator="@null" />

</LinearLayout>
