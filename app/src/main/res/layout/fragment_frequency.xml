<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="24dp"
    android:fitsSystemWindows="true">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="start"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_arrow_back"
        android:tint="@color/on_surface"
        android:contentDescription="뒤로가기" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="주 운동 횟수"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/on_surface"
        android:layout_marginTop="20dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="일주일에 몇 번 운동할 수 있나요?"
        android:textSize="14sp"
        android:textColor="@color/on_surface_secondary"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="28dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 2일 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_freq_2"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:text="2"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:background="@drawable/bg_chip_unselected" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="주 2일"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="가벼운 시작"
                            android:textSize="12sp"
                            android:textColor="@color/on_surface_secondary" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/check_freq_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓"
                        android:textSize="18sp"
                        android:textColor="@color/primary"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3일 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_freq_3"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:text="3"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:background="@drawable/bg_chip_unselected" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="주 3일"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="초보자 추천"
                            android:textSize="12sp"
                            android:textColor="@color/on_surface_secondary" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/check_freq_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓"
                        android:textSize="18sp"
                        android:textColor="@color/primary"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4일 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_freq_4"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:text="4"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:background="@drawable/bg_chip_unselected" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="주 4일"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="표준 루틴"
                            android:textSize="12sp"
                            android:textColor="@color/on_surface_secondary" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/check_freq_4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓"
                        android:textSize="18sp"
                        android:textColor="@color/primary"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 5일 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_freq_5"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:text="5"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:background="@drawable/bg_chip_unselected" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="주 5일"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="중급자 추천"
                            android:textSize="12sp"
                            android:textColor="@color/on_surface_secondary" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/check_freq_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓"
                        android:textSize="18sp"
                        android:textColor="@color/primary"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 6일 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_freq_6"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:gravity="center"
                        android:text="6"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:background="@drawable/bg_chip_unselected" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="주 6일"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="집중 트레이닝"
                            android:textSize="12sp"
                            android:textColor="@color/on_surface_secondary" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/check_freq_6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓"
                        android:textSize="18sp"
                        android:textColor="@color/primary"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btn_next_frequency"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:text="추천받기"
        android:background="@drawable/btn_rectangle"
        app:backgroundTint="@color/primary"
        android:textColor="@color/on_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:enabled="false"
        android:alpha="0.5"
        android:stateListAnimator="@null" />

</LinearLayout>
